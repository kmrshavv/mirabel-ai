@app.post("/analyze-document")
async def analyze_document(request: DocumentRequest):
    """Analyze uploaded documents using the document model"""
    
    analysis_prompt = f"""Please analyze this {request.doc_type} document and provide:
    1. A brief summary (2-3 sentences)
    2. Key points or main arguments
    3. Any important insights
    
    DOCUMENT CONTENT:
    {request.content[:3000]}  # Limit for performance
    """
    
    response = query_ollama("granite3-dense:8b", analysis_prompt)
    return {"analysis": response, "document_type": request.doc_type}


# ============================================================================
# CONVERSATION MANAGEMENT ENDPOINTS (Google Drive)
# ============================================================================

@app.get("/conversations")
async def get_google_drive_conversations(limit: int = 10):
    """Get recent conversations from Google Drive memory"""
    if not MEMORY_AVAILABLE:
        return {"error": "Google Drive memory not available", "conversations": []}
    
    try:
        conversations = memory.load_conversations()
        recent = conversations[-limit:] if conversations else []
        return {
            "total": len(conversations) if conversations else 0,
            "conversations": recent,
            "memory_enabled": True,
            "source": "google_drive"
        }
    except Exception as e:
        return {"error": str(e), "conversations": []}


# ============================================================================
# DATABASE CONVERSATION MANAGEMENT ENDPOINTS
# ============================================================================

@app.get("/db/conversations/{user_id}")
async def get_user_conversations(user_id: int, limit: int = 20):
    """Get user's conversation list from database"""
    if not DB_MANAGER_AVAILABLE:
        return {"error": "Database manager not available", "conversations": []}
    
    try:
        conversations = db_manager.get_user_conversations(user_id, limit)
        return [{
            "id": c.id, 
            "title": c.title, 
            "updated_at": c.updated_at.isoformat(),
            "created_at": c.created_at.isoformat()
        } for c in conversations]
    except Exception as e:
        return {"error": str(e), "conversations": []}

@app.get("/db/conversation/{conv_id}/messages")
async def get_conversation_messages(conv_id: int, limit: int = 50):
    """Get messages from a specific conversation"""
    if not DB_MANAGER_AVAILABLE:
        return {"error": "Database manager not available", "messages": []}
    
    try:
        messages = db_manager.get_conversation_history(conv_id, limit)
        return [{
            "role": m.role, 
            "content": m.content, 
            "created_at": m.created_at.isoformat()
        } for m in messages]
    except Exception as e:
        return {"error": str(e), "messages": []}

@app.post("/db/conversation/new")
async def create_new_conversation(request: NewConversationRequest):
    """Create a new conversation in database"""
    if not DB_MANAGER_AVAILABLE:
        return {"error": "Database manager not available"}
    
    try:
        conv = db_manager.create_conversation(request.user_id, request.title)
        return {
            "id": conv.id, 
            "title": conv.title, 
            "created_at": conv.created_at.isoformat(),
            "message": "Conversation created successfully"
        }
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))

@app.delete("/db/conversation/{conv_id}")
async def delete_conversation(conv_id: int):
    """Delete a conversation and all its messages"""
    if not DB_MANAGER_AVAILABLE:
        return {"error": "Database manager not available"}
    
    try:
        # Delete messages first
        db_manager.db.query(Message).filter(Message.conversation_id == conv_id).delete()
        # Delete conversation
        result = db_manager.db.query(Conversation).filter(Conversation.id == conv_id).delete()
        db_manager.db.commit()
        
        if result == 0:
            raise HTTPException(status_code=404, detail="Conversation not found")
        
        return {"message": "Conversation deleted successfully", "conversation_id": conv_id}
    except HTTPException:
        raise
    except Exception as e:
        db_manager.db.rollback()
        raise HTTPException(status_code=500, detail=str(e))

@app.put("/db/conversation/{conv_id}")
async def update_conversation_title(conv_id: int, title: str):
    """Update conversation title"""
    if not DB_MANAGER_AVAILABLE:
        return {"error": "Database manager not available"}
    
    try:
        conv = db_manager.db.query(Conversation).filter(Conversation.id == conv_id).first()
        if not conv:
            raise HTTPException(status_code=404, detail="Conversation not found")
        
        conv.title = title
        db_manager.db.commit()
        
        return {"id": conv.id, "title": conv.title, "message": "Title updated successfully"}
    except HTTPException:
        raise
    except Exception as e:
        db_manager.db.rollback()
        raise HTTPException(status_code=500, detail=str(e))


