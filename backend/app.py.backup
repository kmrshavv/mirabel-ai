@app.get("/health")
async def health_check():
    """Comprehensive health check for all components"""
    ollama_status = check_ollama_connection()
    available_models = get_available_models() if ollama_status else []
    
    return {
        "status": "healthy" if ollama_status else "degraded",
        "ollama_connected": ollama_status,
        "google_drive_memory": MEMORY_AVAILABLE,
        "database_memory": DB_MANAGER_AVAILABLE,
        "available_models": available_models,
        "model_count": len(available_models),
        "backend_port": 8000,
        "message": "Mirabel AI is ready to chat!"
    }

@app.get("/models")
async def list_models():
    """Get available models from Ollama"""
    try:
        response = requests.get("http://localhost:11434/api/tags", timeout=5)
        if response.status_code == 200:
            models = response.json().get("models", [])
            return {
                "models": [{"name": m["name"], "size_gb": round(m.get("size", 0) / 1e9, 2)} for m in models],
                "count": len(models)
            }
        return {"models": [], "error": "Cannot fetch models"}
    except Exception as e:
        return {"models": [], "error": f"Ollama not running: {str(e)}"}

@app.get("/models/status")
async def get_model_status():
    """Get detailed status of all Ollama models using CLI"""
    try:
        result = subprocess.run(['ollama', 'list'], capture_output=True, text=True, timeout=10)
        models = []
        for line in result.stdout.split('\n')[1:]:
            if line.strip():
                parts = line.split()
                if len(parts) >= 2:
                    models.append({
                        "name": parts[0],
                        "size": parts[1] if len(parts) > 1 else "unknown",
                        "status": "available"
                    })
        return {"models": models, "total": len(models)}
    except Exception as e:
        return {"error": str(e), "models": [], "total": 0}

@app.post("/chat")
async def chat(request: ChatRequest):
    """Main chat endpoint with intelligent routing and memory integration"""
    
    # Get available models
    available_models = get_available_models()
    if not available_models:
        raise HTTPException(status_code=503, detail="No Ollama models available. Please pull a model first.")
    
    # Determine which model to use
    if request.model and request.model in available_models:
        model_to_use = request.model
    else:
        model_to_use = detect_model_type(request.message)
        if model_to_use not in available_models:
            model_to_use = available_models[0] if available_models else "llama3.2:3b"
    
    # Detect task type
    task_mapping = {
        "qwen": "coder",
        "mistral": "researcher", 
        "granite": "document",
        "llama": "emotional"
    }
    detected_task = "general"
    for key, task in task_mapping.items():
        if key in model_to_use:
            detected_task = task
            break
    
    # Get memory context from Google Drive
    memory_context = ""
    if MEMORY_AVAILABLE:
        try:
            memory_context = memory.get_context_for_prompt(limit=3)
        except Exception as e:
            print(f"Memory context error: {e}")
    
    # Prepare system prompt for emotional model
    system_prompt = None
    if "llama" in model_to_use and request.use_emotion_prompt:
        system_prompt = EMOTION_SYSTEM_PROMPT
    
    # Combine memory context with user message
    final_message = request.message
    if memory_context:
        final_message = f"Previous conversation context:\n{memory_context}\n\nCurrent message: {request.message}"
    
    # Database integration: Get or create user and conversation
    user = None
    conversation = None
    if DB_MANAGER_AVAILABLE:
        try:
            user = get_or_create_user("rishav")
            if user:
                conversation = get_active_conversation(user.id, request.conversation_id)
                
                # Save user message to database
                if conversation:
                    db_manager.add_message(conversation.id, "user", request.message)
        except Exception as e:
            print(f"Database save error (user message): {e}")
    
    # Query Ollama
    try:
        reply = query_ollama(model_to_use, final_message, system_prompt)
        
        # Save to Google Drive memory
        if MEMORY_AVAILABLE:
            try:
                memory.save_conversation(request.message, reply, model_to_use)
                print(f"💾 Saved to Google Drive memory")
            except Exception as e:
                print(f"⚠️ Failed to save to Google Drive: {e}")
        
        # Save to database memory
        if DB_MANAGER_AVAILABLE and conversation:
            try:
                db_manager.add_message(conversation.id, "assistant", reply)
                print(f"💾 Saved to database memory")
            except Exception as e:
                print(f"⚠️ Failed to save to database: {e}")
        
        return {
            "reply": reply,
            "model_used": model_to_use,
            "detected_task": detected_task,
            "conversation_id": conversation.id if conversation else None,
            "memory_enabled": MEMORY_AVAILABLE,
            "database_enabled": DB_MANAGER_AVAILABLE
        }
    except Exception as e:
        raise HTTPException(status_code=500, detail=f"Ollama error: {str(e)}")


